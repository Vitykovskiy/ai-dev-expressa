{
  "meta": {
    "product": "Expressa",
    "interface": "customer-web",
    "version": "1.1.0",
    "language": "ru",
    "platform": "mobile-web (Telegram WebApp)",
    "changelog": [
      "v1.1.0: Меню разбито на два экрана (категории + товары категории)",
      "v1.1.0: TopBar стал персистентным на всех экранах кроме welcome",
      "v1.1.0: Убраны все изображения товаров",
      "v1.1.0: Размеры и допы переведены на Chip-компонент с ценой внутри",
      "v1.1.0: Нижняя панель товара — счётчик количества + кнопка с суммой"
    ],
    "viewport": {
      "width": 390,
      "safe_area_top": 44,
      "safe_area_bottom": 34,
      "design_unit": "px"
    }
  },

  "design_tokens": {
    "colors": {
      "background_primary": "#1A1AFF",
      "background_secondary": "#0D0DCC",
      "background_surface": "#FFFFFF",
      "background_surface_muted": "#F2F2F2",
      "background_overlay": "rgba(0, 0, 0, 0.4)",
      "text_primary": "#FFFFFF",
      "text_primary_inverted": "#1A1AFF",
      "text_secondary": "rgba(255,255,255,0.6)",
      "text_body_on_white": "#111111",
      "text_muted_on_white": "#888888",
      "accent": "#FFFFFF",
      "accent_foreground": "#1A1AFF",
      "accent_action": "#FF6B00",
      "accent_action_foreground": "#FFFFFF",
      "destructive": "#FF3B30",
      "success": "#34C759",
      "border": "rgba(255,255,255,0.2)",
      "border_on_white": "#E0E0E0"
    },
    "typography": {
      "font_family_display": "serif",
      "font_family_body": "sans-serif",
      "scale": {
        "display": { "size": 40, "weight": 700, "line_height": 1.1, "transform": "uppercase" },
        "h1": { "size": 28, "weight": 700, "line_height": 1.2 },
        "h2": { "size": 22, "weight": 700, "line_height": 1.3 },
        "h3": { "size": 17, "weight": 600, "line_height": 1.4 },
        "body": { "size": 15, "weight": 400, "line_height": 1.5 },
        "caption": { "size": 12, "weight": 400, "line_height": 1.4 },
        "label": { "size": 13, "weight": 500, "line_height": 1.0 },
        "price": { "size": 20, "weight": 700, "line_height": 1.0 }
      }
    },
    "spacing": {
      "xs": 4,
      "sm": 8,
      "md": 16,
      "lg": 24,
      "xl": 32,
      "xxl": 48
    },
    "border_radius": {
      "sm": 8,
      "md": 16,
      "lg": 20,
      "pill": 999
    },
    "shadows": {
      "card": "0 4px 24px rgba(0,0,0,0.12)",
      "bottom_bar": "0 -1px 0 rgba(255,255,255,0.1)"
    },
    "animation": {
      "duration_fast": "150ms",
      "duration_default": "250ms",
      "easing": "ease-in-out"
    }
  },

  "components": {
    "PersistentTopBar": {
      "description": "Единый хедер присутствует на всех экранах кроме welcome. Всегда фиксирован сверху.",
      "height": 56,
      "background": "color.background_primary",
      "border_bottom": "color.border",
      "safe_area_aware": true,
      "layout": "row space-between align-center",
      "padding": "0 16px",
      "elements": {
        "left": {
          "variants": {
            "home": {
              "type": "logo_text",
              "content": "Expressa",
              "font": "typography.scale.h3",
              "color": "color.text_primary"
            },
            "back": {
              "type": "icon_button",
              "icon": "chevron-left",
              "color": "color.text_primary",
              "size": 24,
              "touch_target": 44
            }
          },
          "note": "Логотип на menu_categories. Стрелка назад на всех вложенных экранах."
        },
        "center": {
          "type": "text",
          "font": "typography.scale.h3",
          "color": "color.text_primary",
          "align": "center",
          "visible_when": "left === back"
        },
        "right": {
          "layout": "row gap-4",
          "items": [
            {
              "id": "nav_history",
              "type": "icon_button",
              "icon": "clock-rotate-left",
              "color": "color.text_primary",
              "size": 22,
              "touch_target": 44,
              "action": "navigate",
              "target": "order_history"
            },
            {
              "id": "nav_cart",
              "type": "icon_button",
              "icon": "shopping-basket",
              "color": "color.text_primary",
              "size": 22,
              "touch_target": 44,
              "action": "navigate",
              "target": "cart",
              "badge": {
                "component": "CartBadge",
                "visible_when": "cart.item_count > 0"
              }
            }
          ]
        }
      }
    },
    "CartBadge": {
      "position": "top-right",
      "offset": { "x": -2, "y": -2 },
      "background": "color.destructive",
      "color": "#FFFFFF",
      "size": 18,
      "font": "typography.scale.caption"
    },
    "Button": {
      "variants": {
        "primary": {
          "background": "color.accent",
          "color": "color.accent_foreground",
          "border_radius": "border_radius.pill",
          "padding": "14px 32px",
          "font": "typography.scale.label",
          "transform": "uppercase",
          "letter_spacing": "0.08em"
        },
        "action": {
          "description": "Оранжевая кнопка добавления в корзину",
          "background": "color.accent_action",
          "color": "color.accent_action_foreground",
          "border_radius": "border_radius.pill",
          "padding": "14px 24px",
          "font": "typography.scale.label",
          "transform": "uppercase"
        },
        "secondary": {
          "background": "transparent",
          "color": "color.accent",
          "border": "1.5px solid color.accent",
          "border_radius": "border_radius.pill",
          "padding": "14px 32px",
          "font": "typography.scale.label"
        },
        "ghost": {
          "background": "rgba(255,255,255,0.12)",
          "color": "color.text_primary",
          "border_radius": "border_radius.pill",
          "padding": "12px 24px"
        }
      },
      "states": {
        "disabled": { "opacity": 0.4, "pointer_events": "none" },
        "loading": { "show_spinner": true, "text": "hidden" },
        "pressed": { "scale": 0.97 }
      }
    },
    "Chip": {
      "description": "Универсальный чип выбора. Используется для размеров, допов и фильтров.",
      "layout": "inline-flex align-center",
      "border_radius": "border_radius.pill",
      "padding": "8px 16px",
      "font": "typography.scale.label",
      "states": {
        "default": {
          "background": "transparent",
          "color": "color.text_primary",
          "border": "1.5px solid color.border"
        },
        "selected": {
          "background": "color.accent",
          "color": "color.accent_foreground",
          "border": "none"
        },
        "disabled": {
          "background": "rgba(255,255,255,0.04)",
          "color": "rgba(255,255,255,0.25)",
          "border": "1.5px solid rgba(255,255,255,0.08)",
          "pointer_events": "none"
        }
      },
      "price_suffix": {
        "format_paid": "{label} · {price} ₽",
        "format_free": "{label}",
        "separator": " · "
      }
    },
    "ChipGroup": {
      "description": "Горизонтальная группа чипов с переносом строки.",
      "layout": "flex wrap",
      "gap": "spacing.sm",
      "section_label": {
        "font": "typography.scale.caption",
        "color": "color.text_secondary",
        "transform": "uppercase",
        "letter_spacing": "0.06em",
        "margin_bottom": "spacing.sm"
      }
    },
    "CategoryCard": {
      "description": "Карточка группы меню. Без изображения.",
      "background": "rgba(255,255,255,0.1)",
      "border_radius": "border_radius.lg",
      "padding": "20px 16px",
      "layout": "row space-between align-center",
      "elements": {
        "name": { "font": "typography.scale.h3", "color": "color.text_primary" },
        "count": { "font": "typography.scale.caption", "color": "color.text_secondary" },
        "chevron": { "icon": "chevron-right", "color": "color.text_secondary", "size": 18 }
      },
      "states": {
        "pressed": { "background": "rgba(255,255,255,0.16)" }
      }
    },
    "ProductRow": {
      "description": "Строка товара в списке категории. Без изображения. Чипы-превью размеров/вариантов.",
      "background": "rgba(255,255,255,0.08)",
      "border_radius": "border_radius.lg",
      "padding": "16px",
      "layout": "vertical gap-8",
      "elements": {
        "category_label": {
          "font": "typography.scale.caption",
          "color": "color.text_secondary",
          "transform": "uppercase",
          "letter_spacing": "0.06em"
        },
        "name": { "font": "typography.scale.h3", "color": "color.text_primary" },
        "chips_preview": {
          "description": "Нередактируемые чипы с ценами для предпросмотра вариантов",
          "component": "ChipGroup",
          "interactive": false,
          "chip_state": "default",
          "max_visible": 3
        }
      },
      "states": {
        "unavailable": {
          "opacity": 0.4,
          "pointer_events": "none",
          "label": {
            "text": "Недоступно",
            "font": "typography.scale.caption",
            "color": "color.text_secondary"
          }
        }
      }
    },
    "QuantityControl": {
      "description": "Счётчик количества на экране product.",
      "layout": "row align-center gap-16",
      "button": {
        "size": 36,
        "border_radius": "border_radius.pill",
        "background": "rgba(255,255,255,0.15)",
        "color": "color.text_primary",
        "icon_minus": "minus",
        "icon_plus": "plus",
        "icon_size": 18
      },
      "value": {
        "font": "typography.scale.h3",
        "color": "color.text_primary",
        "min_width": 32,
        "align": "center"
      },
      "min": 1,
      "max": 10
    },
    "AddToCartBar": {
      "description": "Фиксированная нижняя панель на экране product. Счётчик слева, кнопка с суммой справа.",
      "position": "fixed bottom",
      "height": 72,
      "safe_area_aware": true,
      "background": "color.background_primary",
      "border_top": "color.border",
      "padding": "12px 16px",
      "layout": "row space-between align-center",
      "elements": {
        "quantity_control": "QuantityControl",
        "add_button": {
          "component": "Button",
          "variant": "action",
          "label": "Добавить · {total_price} ₽",
          "flex": 1,
          "margin_left": "spacing.md",
          "disabled_when": "product.has_sizes && size_not_selected"
        }
      }
    },
    "CartItem": {
      "layout": "vertical",
      "background": "rgba(255,255,255,0.08)",
      "border_radius": "border_radius.lg",
      "padding": "14px 16px",
      "elements": {
        "header_row": {
          "layout": "row space-between align-start",
          "name": { "font": "typography.scale.h3", "color": "color.text_primary" },
          "remove_button": { "icon": "x", "color": "color.text_secondary", "size": 18 }
        },
        "modifiers": {
          "font": "typography.scale.caption",
          "color": "color.text_secondary",
          "margin_top": "spacing.xs"
        },
        "footer_row": {
          "layout": "row space-between align-center",
          "margin_top": "spacing.sm",
          "price": { "font": "typography.scale.price", "color": "color.text_primary" },
          "quantity_note": { "font": "typography.scale.caption", "color": "color.text_secondary" }
        }
      }
    },
    "SlotButton": {
      "layout": "grid_3_columns",
      "gap": "spacing.sm",
      "item": {
        "border_radius": "border_radius.md",
        "padding": "12px 8px",
        "font": "typography.scale.label",
        "align": "center",
        "states": {
          "available": {
            "background": "rgba(255,255,255,0.1)",
            "color": "color.text_primary",
            "border": "1px solid color.border"
          },
          "selected": {
            "background": "color.accent",
            "color": "color.accent_foreground"
          },
          "full": {
            "background": "rgba(255,255,255,0.03)",
            "color": "rgba(255,255,255,0.25)",
            "border": "1px solid rgba(255,255,255,0.06)",
            "pointer_events": "none"
          }
        }
      }
    },
    "OrderCard": {
      "background": "rgba(255,255,255,0.1)",
      "border_radius": "border_radius.lg",
      "padding": "16px",
      "layout": "vertical gap-8",
      "elements": {
        "header_row": {
          "layout": "row space-between",
          "order_number": { "font": "typography.scale.caption", "color": "color.text_secondary" },
          "status_badge": "StatusBadge"
        },
        "items_summary": { "font": "typography.scale.body", "color": "color.text_primary" },
        "footer_row": {
          "layout": "row space-between",
          "slot_time": { "font": "typography.scale.caption", "color": "color.text_secondary", "icon": "clock" },
          "total": { "font": "typography.scale.price", "color": "color.text_primary" }
        }
      }
    },
    "StatusBadge": {
      "border_radius": "border_radius.pill",
      "padding": "4px 12px",
      "font": "typography.scale.caption",
      "variants": {
        "Created":          { "background": "rgba(255,255,255,0.15)", "color": "#FFFFFF" },
        "Confirmed":        { "background": "rgba(52,199,89,0.2)",    "color": "#34C759" },
        "Ready for pickup": { "background": "rgba(255,149,0,0.2)",    "color": "#FF9500" },
        "Rejected":         { "background": "rgba(255,59,48,0.2)",    "color": "#FF3B30" },
        "Closed":           { "background": "rgba(255,255,255,0.08)", "color": "rgba(255,255,255,0.4)" }
      }
    },
    "EmptyState": {
      "padding": "48px 24px",
      "icon_size": 56,
      "icon_color": "rgba(255,255,255,0.25)",
      "title": { "font": "typography.scale.h2", "color": "color.text_primary" },
      "subtitle": { "font": "typography.scale.body", "color": "color.text_secondary" }
    },
    "Toast": {
      "position": "bottom",
      "margin_bottom": 96,
      "background": "rgba(20,20,20,0.92)",
      "color": "#FFFFFF",
      "border_radius": "border_radius.pill",
      "padding": "12px 20px",
      "font": "typography.scale.body",
      "duration_ms": 3000
    }
  },

  "screens": [
    {
      "id": "welcome",
      "name": "Welcome",
      "route": "/",
      "description": "Первый экран. Без TopBar.",
      "background": "color.background_primary",
      "topbar": "none",
      "layout": "full_screen_centered",
      "elements": [
        {
          "id": "welcome_logo",
          "type": "text",
          "content": "Expressa",
          "style": "typography.scale.display",
          "color": "color.text_primary"
        },
        {
          "id": "welcome_tagline",
          "type": "text",
          "content": "Закажи. Забери. Наслаждайся.",
          "style": "typography.scale.body",
          "color": "color.text_secondary"
        },
        {
          "id": "welcome_illustration",
          "type": "illustration",
          "description": "Контурная иконка чашки, белая, ~160px"
        },
        {
          "id": "welcome_cta",
          "type": "Button",
          "variant": "primary",
          "label": "Смотреть меню",
          "action": "navigate",
          "target": "menu_categories"
        }
      ]
    },
    {
      "id": "menu_categories",
      "name": "Menu — Categories",
      "route": "/menu",
      "description": "Главный экран каталога. Список групп меню. TopBar с логотипом.",
      "background": "color.background_primary",
      "topbar": {
        "component": "PersistentTopBar",
        "left": "home",
        "center": null,
        "right": ["nav_history", "nav_cart"]
      },
      "layout": "scroll_vertical",
      "elements": [
        {
          "id": "categories_heading",
          "type": "text",
          "content": "Меню",
          "style": "typography.scale.h1",
          "color": "color.text_primary",
          "padding": "16px 16px 8px"
        },
        {
          "id": "categories_list",
          "type": "List",
          "item_component": "CategoryCard",
          "gap": "spacing.sm",
          "padding": "0 16px 24px",
          "on_tap": "navigate to menu_category_products"
        }
      ],
      "states": {
        "loading": { "show": "skeleton CategoryCards x 5" },
        "empty": {
          "component": "EmptyState",
          "icon": "coffee-cup",
          "title": "Меню пока пусто",
          "subtitle": "Загляни позже"
        }
      }
    },
    {
      "id": "menu_category_products",
      "name": "Menu — Category Products",
      "route": "/menu/:category_id",
      "description": "Список товаров выбранной категории с чип-превью цен и размеров.",
      "background": "color.background_primary",
      "topbar": {
        "component": "PersistentTopBar",
        "left": "back",
        "center": "{category_name}",
        "right": ["nav_history", "nav_cart"]
      },
      "layout": "scroll_vertical",
      "elements": [
        {
          "id": "category_meta",
          "type": "Section",
          "padding": "8px 16px 16px",
          "elements": [
            {
              "id": "category_count",
              "type": "text",
              "content": "{count} позиций",
              "style": "typography.scale.caption",
              "color": "color.text_secondary",
              "transform": "uppercase",
              "letter_spacing": "0.06em"
            },
            {
              "id": "category_name_large",
              "type": "text",
              "content": "{category_name}",
              "style": "typography.scale.h1",
              "color": "color.text_primary"
            }
          ]
        },
        {
          "id": "products_list",
          "type": "List",
          "item_component": "ProductRow",
          "gap": "spacing.sm",
          "padding": "0 16px 24px",
          "on_tap": "navigate to product"
        }
      ],
      "states": {
        "loading": { "show": "skeleton ProductRows x 4" },
        "empty": {
          "component": "EmptyState",
          "icon": "coffee-cup",
          "title": "Нет товаров",
          "subtitle": "В этой категории пока ничего нет"
        }
      }
    },
    {
      "id": "product",
      "name": "Product",
      "route": "/product/:id",
      "description": "Карточка товара. Без изображения. Размеры и допы — чипы. Нижняя панель — счётчик + кнопка.",
      "background": "color.background_primary",
      "topbar": {
        "component": "PersistentTopBar",
        "left": "back",
        "center": null,
        "right": ["nav_history", "nav_cart"]
      },
      "layout": "scroll_vertical",
      "padding_bottom": 88,
      "elements": [
        {
          "id": "product_meta",
          "type": "Section",
          "padding": "8px 16px 16px",
          "elements": [
            {
              "id": "product_category_label",
              "type": "text",
              "content": "{category_name}",
              "style": "typography.scale.caption",
              "color": "color.text_secondary",
              "transform": "uppercase",
              "letter_spacing": "0.06em"
            },
            {
              "id": "product_name",
              "type": "text",
              "content": "{product_name}",
              "style": "typography.scale.h1",
              "color": "color.text_primary"
            },
            {
              "id": "product_base_price",
              "type": "text",
              "content": "{base_price} ₽",
              "style": "typography.scale.price",
              "color": "color.text_primary",
              "note": "Обновляется при выборе размера/варианта"
            }
          ]
        },
        {
          "id": "product_description",
          "type": "text",
          "content": "{description}",
          "style": "typography.scale.body",
          "color": "color.text_secondary",
          "padding": "0 16px 24px",
          "visible_when": "product.description != null"
        },
        {
          "id": "product_size_group",
          "type": "Section",
          "visible_when": "product.has_sizes === true",
          "padding": "0 16px 24px",
          "elements": [
            {
              "id": "size_label",
              "type": "text",
              "content": "РАЗМЕР",
              "style": "typography.scale.caption",
              "color": "color.text_secondary",
              "letter_spacing": "0.06em",
              "margin_bottom": "spacing.sm"
            },
            {
              "id": "size_chips",
              "type": "ChipGroup",
              "source": "product.sizes",
              "chip_format": "{size_label} · {price} ₽",
              "selection": "single_required",
              "on_select": "update product_base_price and AddToCartBar total"
            }
          ]
        },
        {
          "id": "product_addons",
          "type": "List",
          "visible_when": "product.addon_groups.length > 0",
          "padding": "0 16px 24px",
          "gap": "spacing.lg",
          "item": {
            "type": "Section",
            "elements": [
              {
                "id": "addon_group_label",
                "type": "text",
                "content": "{group_name}",
                "style": "typography.scale.caption",
                "color": "color.text_secondary",
                "transform": "uppercase",
                "letter_spacing": "0.06em",
                "margin_bottom": "spacing.sm"
              },
              {
                "id": "addon_chips",
                "type": "ChipGroup",
                "source": "addon_group.items",
                "chip_format_paid": "{addon_name} · {price} ₽",
                "chip_format_free": "{addon_name}",
                "selection_single": "single_optional (exclusive within group)",
                "selection_multiple": "multi_optional",
                "on_select": "update AddToCartBar total"
              }
            ]
          }
        },
        {
          "id": "product_add_bar",
          "type": "AddToCartBar"
        }
      ],
      "states": {
        "size_not_selected": {
          "add_button": "disabled",
          "hint": {
            "text": "Выбери размер",
            "position": "above AddToCartBar",
            "font": "typography.scale.caption",
            "color": "color.text_secondary",
            "align": "center"
          }
        },
        "added": {
          "toast": "Добавлено в корзину",
          "action": "navigate_back"
        }
      }
    },
    {
      "id": "cart",
      "name": "Cart",
      "route": "/cart",
      "description": "Корзина. Список позиций, итог, переход к выбору слота.",
      "background": "color.background_primary",
      "topbar": {
        "component": "PersistentTopBar",
        "left": "back",
        "center": "Корзина",
        "right": ["nav_history"]
      },
      "layout": "scroll_vertical",
      "elements": [
        {
          "id": "cart_items",
          "type": "List",
          "item_component": "CartItem",
          "gap": "spacing.sm",
          "padding": "16px 16px 0"
        },
        {
          "id": "cart_total_row",
          "type": "Row",
          "layout": "row space-between",
          "padding": "20px 16px",
          "elements": [
            { "type": "text", "content": "Итого", "style": "typography.scale.h3", "color": "color.text_primary" },
            { "type": "text", "source": "cart.total", "format": "{total} ₽", "style": "typography.scale.price", "color": "color.text_primary" }
          ]
        },
        {
          "id": "cart_checkout_button",
          "type": "Button",
          "variant": "primary",
          "label": "Выбрать время",
          "action": "navigate",
          "target": "slot_picker",
          "margin": "0 16px",
          "sticky": "bottom",
          "safe_area_aware": true
        }
      ],
      "states": {
        "empty": {
          "component": "EmptyState",
          "icon": "shopping-basket",
          "title": "Корзина пуста",
          "subtitle": "Добавь что-нибудь из меню",
          "cta": { "label": "В меню", "target": "menu_categories" }
        },
        "item_removed": { "toast": "Позиция удалена" }
      }
    },
    {
      "id": "slot_picker",
      "name": "Slot Picker",
      "route": "/slot",
      "description": "Выбор времени получения. Текущий день, шаг 10 минут.",
      "background": "color.background_primary",
      "topbar": {
        "component": "PersistentTopBar",
        "left": "back",
        "center": "Время получения",
        "right": ["nav_history", "nav_cart"]
      },
      "layout": "scroll_vertical",
      "elements": [
        {
          "id": "slot_date_label",
          "type": "text",
          "content": "Сегодня, {date}",
          "style": "typography.scale.h3",
          "color": "color.text_secondary",
          "padding": "16px 16px 8px"
        },
        {
          "id": "slot_legend",
          "type": "Legend",
          "layout": "row gap-16",
          "padding": "0 16px 16px",
          "items": [
            { "chip_state": "available", "label": "Доступен" },
            { "chip_state": "selected",  "label": "Выбран" },
            { "chip_state": "full",      "label": "Занят" }
          ]
        },
        {
          "id": "slot_grid",
          "type": "SlotButton",
          "padding": "0 16px",
          "data_source": "available_slots_today",
          "step_minutes": 10
        },
        {
          "id": "slot_confirm_button",
          "type": "Button",
          "variant": "primary",
          "label": "Подтвердить заказ",
          "action": "create_order",
          "disabled_when": "slot_not_selected",
          "margin": "24px 16px 0",
          "sticky": "bottom",
          "safe_area_aware": true
        }
      ],
      "states": {
        "slot_not_selected": { "confirm_button": "disabled" },
        "no_slots_available": {
          "component": "EmptyState",
          "icon": "clock",
          "title": "Свободных слотов нет",
          "subtitle": "Все слоты на сегодня заняты. Попробуй позже."
        },
        "order_created": {
          "action": "navigate",
          "target": "order_history",
          "toast": "Заказ оформлен!"
        },
        "outside_working_hours": {
          "component": "EmptyState",
          "icon": "clock",
          "title": "Мы сейчас закрыты",
          "subtitle": "Заказы принимаются с {open} до {close}"
        }
      }
    },
    {
      "id": "order_history",
      "name": "Order History",
      "route": "/orders",
      "description": "История заказов пользователя. Последний вверху.",
      "background": "color.background_primary",
      "topbar": {
        "component": "PersistentTopBar",
        "left": "back",
        "center": "Мои заказы",
        "right": ["nav_cart"]
      },
      "layout": "scroll_vertical",
      "elements": [
        {
          "id": "history_list",
          "type": "List",
          "item_component": "OrderCard",
          "sort": "created_at DESC",
          "gap": "spacing.sm",
          "padding": "16px",
          "on_tap": "navigate to order_detail"
        }
      ],
      "states": {
        "loading": { "show": "skeleton OrderCards x 3" },
        "empty": {
          "component": "EmptyState",
          "icon": "receipt",
          "title": "Заказов пока нет",
          "subtitle": "Оформи первый заказ",
          "cta": { "label": "В меню", "target": "menu_categories" }
        }
      }
    },
    {
      "id": "order_detail",
      "name": "Order Detail",
      "route": "/orders/:id",
      "description": "Детали заказа: статус, состав, слот, сумма.",
      "background": "color.background_primary",
      "topbar": {
        "component": "PersistentTopBar",
        "left": "back",
        "center": "Заказ #{order_number}",
        "right": ["nav_cart"]
      },
      "layout": "scroll_vertical",
      "elements": [
        {
          "id": "detail_status_block",
          "type": "Section",
          "background": "rgba(255,255,255,0.08)",
          "border_radius": "border_radius.lg",
          "margin": "16px",
          "padding": "16px",
          "elements": [
            { "id": "detail_status_badge", "type": "StatusBadge" },
            {
              "id": "detail_status_description",
              "type": "text",
              "style": "typography.scale.body",
              "color": "color.text_secondary",
              "margin_top": "spacing.sm",
              "content_map": {
                "Created":          "Заказ принят, ожидает подтверждения",
                "Confirmed":        "Бариста подтвердил заказ, готовим",
                "Ready for pickup": "Заказ готов — подойди на стойку",
                "Rejected":         "Заказ отклонён. {rejection_reason}",
                "Closed":           "Заказ выдан"
              }
            },
            {
              "id": "detail_slot_row",
              "type": "Row",
              "layout": "row gap-8 align-center",
              "margin_top": "spacing.md",
              "elements": [
                { "type": "icon", "icon": "clock", "size": 16, "color": "color.text_secondary" },
                { "type": "text", "content": "{slot_time}", "style": "typography.scale.body", "color": "color.text_secondary" }
              ]
            }
          ],
          "state_borders": {
            "Rejected":         "1px solid rgba(255,59,48,0.4)",
            "Ready for pickup": "1px solid rgba(255,149,0,0.4)",
            "Confirmed":        "1px solid rgba(52,199,89,0.3)"
          }
        },
        {
          "id": "detail_items_label",
          "type": "text",
          "content": "СОСТАВ ЗАКАЗА",
          "style": "typography.scale.caption",
          "color": "color.text_secondary",
          "letter_spacing": "0.06em",
          "padding": "0 16px 8px"
        },
        {
          "id": "detail_items_list",
          "type": "List",
          "padding": "0 16px",
          "gap": "spacing.sm",
          "item": {
            "layout": "row space-between align-start",
            "background": "rgba(255,255,255,0.08)",
            "border_radius": "border_radius.md",
            "padding": "14px",
            "name": { "font": "typography.scale.h3", "color": "color.text_primary" },
            "modifiers": { "font": "typography.scale.caption", "color": "color.text_secondary", "margin_top": "spacing.xs" },
            "price": { "font": "typography.scale.label", "color": "color.text_primary" }
          }
        },
        {
          "id": "detail_total_row",
          "type": "Row",
          "layout": "row space-between",
          "padding": "20px 16px",
          "elements": [
            { "type": "text", "content": "Итого", "style": "typography.scale.h3", "color": "color.text_primary" },
            { "type": "text", "source": "order.total", "format": "{total} ₽", "style": "typography.scale.price", "color": "color.text_primary" }
          ]
        },
        {
          "id": "detail_payment_note",
          "type": "text",
          "content": "Оплата при получении",
          "style": "typography.scale.caption",
          "color": "color.text_secondary",
          "align": "center",
          "padding": "0 16px 32px"
        }
      ]
    }
  ],

  "navigation": {
    "type": "stack",
    "default_route": "welcome",
    "transitions": {
      "push": "slide-left",
      "pop": "slide-right",
      "duration": "animation.duration_default"
    },
    "flow": {
      "welcome":                ["menu_categories"],
      "menu_categories":        ["menu_category_products", "order_history", "cart"],
      "menu_category_products": ["product", "order_history", "cart"],
      "product":                ["cart", "order_history"],
      "cart":                   ["slot_picker", "order_history"],
      "slot_picker":            ["order_history"],
      "order_history":          ["order_detail", "cart"],
      "order_detail":           ["order_history", "cart"]
    },
    "persistent_nav_note": "nav_history и nav_cart доступны из PersistentTopBar на всех экранах кроме welcome"
  },

  "accessibility": {
    "min_touch_target": 44,
    "contrast_ratio_min": 4.5,
    "focus_visible": true,
    "tap_animation": "scale 0.97 on press"
  },

  "adaptivity": {
    "base_width": 390,
    "max_content_width": 480,
    "layout": "single_column",
    "safe_areas": "respected on all fixed elements",
    "scroll_behavior": "native momentum",
    "keyboard_behavior": "push_content_up on input focus"
  }
}
