{
  "meta": {
    "product": "Expressa",
    "interface": "backoffice-web",
    "version": "1.0.0",
    "language": "ru",
    "platform": "mobile-web + tablet (Telegram WebApp)",
    "viewport": {
      "mobile": { "width": 390, "breakpoint": "< 768px" },
      "tablet": { "width": 768, "breakpoint": ">= 768px" },
      "design_unit": "px"
    },
    "roles": {
      "barista": {
        "tabs": ["orders", "availability"],
        "description": "Операционная работа с заказами и доступностью"
      },
      "administrator": {
        "tabs": ["orders", "availability", "menu", "users", "settings"],
        "description": "Полный доступ включая управление меню, пользователями и настройками"
      }
    }
  },

  "design_tokens": {
    "colors": {
      "background_primary": "#FFFFFF",
      "background_secondary": "#F5F5F7",
      "background_surface": "#FFFFFF",
      "background_surface_raised": "#F5F5F7",
      "text_primary": "#111111",
      "text_secondary": "#555555",
      "text_muted": "#999999",
      "text_on_accent": "#FFFFFF",
      "accent": "#1A1AFF",
      "accent_light": "#E8E8FF",
      "destructive": "#D32F2F",
      "destructive_light": "#FFEBEE",
      "success": "#2E7D32",
      "success_light": "#E8F5E9",
      "warning": "#E65100",
      "warning_light": "#FFF3E0",
      "neutral": "#757575",
      "neutral_light": "#F5F5F5",
      "border": "#E0E0E0",
      "border_strong": "#BDBDBD",
      "overlay": "rgba(0,0,0,0.4)"
    },
    "typography": {
      "font_family": "sans-serif",
      "scale": {
        "h1": { "size": 24, "weight": 700, "line_height": 1.2 },
        "h2": { "size": 18, "weight": 600, "line_height": 1.3 },
        "h3": { "size": 15, "weight": 600, "line_height": 1.4 },
        "body": { "size": 14, "weight": 400, "line_height": 1.5 },
        "caption": { "size": 12, "weight": 400, "line_height": 1.4 },
        "label": { "size": 13, "weight": 500, "line_height": 1.0 },
        "mono": { "size": 13, "weight": 500, "font_family": "monospace" }
      }
    },
    "spacing": {
      "xs": 4,
      "sm": 8,
      "md": 16,
      "lg": 24,
      "xl": 32
    },
    "border_radius": {
      "sm": 6,
      "md": 10,
      "lg": 16,
      "pill": 999
    },
    "shadows": {
      "card": "0 1px 4px rgba(0,0,0,0.08)",
      "modal": "0 8px 32px rgba(0,0,0,0.16)",
      "tab_bar": "0 -1px 0 #E0E0E0"
    },
    "animation": {
      "duration_fast": "120ms",
      "duration_default": "200ms",
      "easing": "ease-in-out"
    }
  },

  "components": {
    "TabBar": {
      "position": "bottom",
      "height_mobile": 60,
      "height_tablet": 0,
      "safe_area_aware": true,
      "background": "color.background_primary",
      "border_top": "color.border",
      "shadow": "shadows.tab_bar",
      "tablet_alternative": "SideNav",
      "item": {
        "icon_size": 22,
        "label": { "font": "typography.scale.caption", "visible_mobile": true },
        "color_active": "color.accent",
        "color_inactive": "color.text_muted",
        "indicator": { "type": "top_line", "color": "color.accent", "height": 2 }
      },
      "tabs": [
        { "id": "orders", "label": "Заказы", "icon": "clipboard-list", "roles": ["barista", "administrator"] },
        { "id": "availability", "label": "Доступность", "icon": "toggle-right", "roles": ["barista", "administrator"] },
        { "id": "menu", "label": "Меню", "icon": "book-open", "roles": ["administrator"] },
        { "id": "users", "label": "Пользователи", "icon": "users", "roles": ["administrator"] },
        { "id": "settings", "label": "Настройки", "icon": "settings", "roles": ["administrator"] }
      ]
    },
    "SideNav": {
      "description": "Заменяет TabBar на планшете",
      "width": 220,
      "position": "left",
      "background": "color.background_secondary",
      "border_right": "color.border",
      "item": {
        "padding": "12px 16px",
        "border_radius": "border_radius.md",
        "color_active": "color.accent",
        "background_active": "color.accent_light",
        "color_inactive": "color.text_secondary",
        "font": "typography.scale.label"
      },
      "header": {
        "logo": "Expressa",
        "role_badge": { "font": "typography.scale.caption", "color": "color.text_muted" }
      }
    },
    "TopBar": {
      "height": 52,
      "background": "color.background_primary",
      "border_bottom": "color.border",
      "elements": {
        "title": { "font": "typography.scale.h2", "color": "color.text_primary" },
        "action_right": { "type": "icon_button", "size": 22, "color": "color.text_secondary" }
      },
      "tablet": {
        "visible": false,
        "note": "На планшете заголовок отображается внутри контентной зоны"
      }
    },
    "Button": {
      "variants": {
        "primary": {
          "background": "color.accent",
          "color": "color.text_on_accent",
          "border_radius": "border_radius.md",
          "padding": "10px 20px",
          "font": "typography.scale.label"
        },
        "secondary": {
          "background": "color.background_secondary",
          "color": "color.text_primary",
          "border": "1px solid color.border",
          "border_radius": "border_radius.md",
          "padding": "10px 20px",
          "font": "typography.scale.label"
        },
        "destructive": {
          "background": "color.destructive_light",
          "color": "color.destructive",
          "border_radius": "border_radius.md",
          "padding": "10px 20px",
          "font": "typography.scale.label"
        },
        "ghost": {
          "background": "transparent",
          "color": "color.text_secondary",
          "border_radius": "border_radius.md",
          "padding": "10px 20px",
          "font": "typography.scale.label"
        }
      },
      "states": {
        "disabled": { "opacity": 0.4, "pointer_events": "none" },
        "loading": { "show_spinner": true },
        "pressed": { "opacity": 0.85 }
      }
    },
    "StatusBadge": {
      "border_radius": "border_radius.pill",
      "padding": "3px 10px",
      "font": "typography.scale.caption",
      "variants": {
        "Created":          { "background": "color.accent_light",      "color": "color.accent" },
        "Confirmed":        { "background": "color.success_light",     "color": "color.success" },
        "Ready for pickup": { "background": "color.warning_light",     "color": "color.warning" },
        "Rejected":         { "background": "color.destructive_light", "color": "color.destructive" },
        "Closed":           { "background": "color.neutral_light",     "color": "color.neutral" }
      }
    },
    "OrderCard": {
      "background": "color.background_surface",
      "border": "1px solid color.border",
      "border_radius": "border_radius.lg",
      "shadow": "shadows.card",
      "padding": "14px 16px",
      "layout": "vertical",
      "elements": {
        "header_row": {
          "layout": "row space-between",
          "order_number": { "font": "typography.scale.mono", "color": "color.text_muted" },
          "status_badge": "StatusBadge",
          "slot_time": { "font": "typography.scale.caption", "color": "color.text_muted", "icon": "clock" }
        },
        "customer_row": {
          "font": "typography.scale.h3",
          "color": "color.text_primary"
        },
        "items_summary": {
          "font": "typography.scale.body",
          "color": "color.text_secondary",
          "max_lines": 2
        },
        "total": {
          "font": "typography.scale.h3",
          "color": "color.text_primary"
        },
        "actions_row": {
          "layout": "row gap-8",
          "position": "bottom",
          "note": "Кнопки действий зависят от текущего статуса заказа"
        }
      },
      "tablet_layout": {
        "note": "На планшете карточки отображаются в сетке 2 колонки"
      }
    },
    "ConfirmDialog": {
      "type": "modal_bottom_sheet_mobile / centered_modal_tablet",
      "background": "color.background_surface",
      "border_radius": "border_radius.lg border_radius.lg 0 0",
      "padding": "24px 16px",
      "elements": {
        "title": { "font": "typography.scale.h2", "color": "color.text_primary" },
        "description": { "font": "typography.scale.body", "color": "color.text_secondary" },
        "input": {
          "visible_when": "action === reject",
          "placeholder": "Причина отклонения",
          "required": true,
          "border": "1px solid color.border",
          "border_radius": "border_radius.md",
          "font": "typography.scale.body",
          "padding": "12px"
        },
        "actions": {
          "layout": "column gap-8",
          "confirm": "Button.primary or Button.destructive",
          "cancel": "Button.ghost"
        }
      }
    },
    "ToggleRow": {
      "layout": "row space-between align-center",
      "padding": "14px 0",
      "border_bottom": "1px solid color.border",
      "elements": {
        "label": { "font": "typography.scale.h3", "color": "color.text_primary" },
        "sublabel": { "font": "typography.scale.caption", "color": "color.text_muted" },
        "toggle": {
          "color_on": "color.accent",
          "color_off": "color.border_strong",
          "size": 24
        }
      },
      "states": {
        "unavailable": {
          "label_color": "color.text_muted",
          "toggle": "off"
        }
      }
    },
    "FormField": {
      "layout": "vertical gap-6",
      "label": { "font": "typography.scale.label", "color": "color.text_secondary" },
      "input": {
        "background": "color.background_surface",
        "border": "1px solid color.border",
        "border_radius": "border_radius.md",
        "padding": "10px 12px",
        "font": "typography.scale.body",
        "color": "color.text_primary",
        "focus_border": "color.accent"
      },
      "error": { "font": "typography.scale.caption", "color": "color.destructive" },
      "hint": { "font": "typography.scale.caption", "color": "color.text_muted" }
    },
    "UserRow": {
      "layout": "row space-between align-center",
      "padding": "14px 0",
      "border_bottom": "1px solid color.border",
      "elements": {
        "avatar": { "size": 36, "border_radius": "border_radius.pill", "background": "color.accent_light", "initials_color": "color.accent" },
        "name": { "font": "typography.scale.h3", "color": "color.text_primary" },
        "role_badge": {
          "font": "typography.scale.caption",
          "border_radius": "border_radius.pill",
          "padding": "2px 8px",
          "variants": {
            "administrator": { "background": "color.accent_light", "color": "color.accent" },
            "barista":        { "background": "color.success_light", "color": "color.success" },
            "customer":       { "background": "color.neutral_light", "color": "color.neutral" }
          }
        },
        "status_badge": {
          "variants": {
            "active":  { "background": "color.success_light", "color": "color.success" },
            "blocked": { "background": "color.destructive_light", "color": "color.destructive" }
          }
        },
        "action_menu": { "icon": "more-vertical", "size": 20, "color": "color.text_muted" }
      }
    },
    "SectionList": {
      "section_header": {
        "font": "typography.scale.label",
        "color": "color.text_muted",
        "transform": "uppercase",
        "letter_spacing": "0.06em",
        "padding": "16px 0 8px"
      },
      "background": "color.background_surface",
      "border_radius": "border_radius.lg",
      "border": "1px solid color.border"
    },
    "EmptyState": {
      "padding": "48px 24px",
      "icon_size": 48,
      "icon_color": "color.text_muted",
      "title": { "font": "typography.scale.h2", "color": "color.text_primary" },
      "subtitle": { "font": "typography.scale.body", "color": "color.text_muted" }
    },
    "Toast": {
      "position": "top",
      "margin_top": 64,
      "border_radius": "border_radius.md",
      "padding": "12px 16px",
      "font": "typography.scale.body",
      "duration_ms": 3000,
      "variants": {
        "success": { "background": "color.success_light", "color": "color.success", "icon": "check-circle" },
        "error":   { "background": "color.destructive_light", "color": "color.destructive", "icon": "alert-circle" },
        "info":    { "background": "color.accent_light", "color": "color.accent", "icon": "info" }
      }
    }
  },

  "screens": [
    {
      "id": "orders",
      "tab": "orders",
      "name": "Заказы",
      "roles": ["barista", "administrator"],
      "description": "Очередь активных заказов. Основной операционный экран баристы.",
      "layout": {
        "mobile": "scroll_vertical",
        "tablet": "two_column — фильтры слева 240px, список справа"
      },
      "elements": [
        {
          "id": "orders_topbar",
          "type": "TopBar",
          "title": "Заказы",
          "action_right": { "icon": "refresh-cw", "action": "reload_orders" }
        },
        {
          "id": "orders_filter_tabs",
          "type": "HorizontalScrollList",
          "items": [
            { "id": "all", "label": "Все" },
            { "id": "created", "label": "Новые" },
            { "id": "confirmed", "label": "Подтверждённые" },
            { "id": "ready", "label": "Готовы" }
          ],
          "style": {
            "item_active_background": "color.accent",
            "item_active_color": "color.text_on_accent",
            "item_inactive_background": "color.background_secondary",
            "item_inactive_color": "color.text_secondary",
            "border_radius": "border_radius.pill",
            "font": "typography.scale.label"
          },
          "behavior": "sticky_below_topbar"
        },
        {
          "id": "orders_list",
          "type": "List",
          "item_component": "OrderCard",
          "sort": "slot_time ASC",
          "gap": "spacing.md",
          "pull_to_refresh": true,
          "tablet_columns": 2
        }
      ],
      "order_actions": {
        "description": "Кнопки действий внутри OrderCard.actions_row зависят от статуса",
        "Created": [
          { "label": "Подтвердить", "variant": "primary", "action": "confirm_order" },
          { "label": "Отклонить", "variant": "destructive", "action": "reject_order", "opens": "ConfirmDialog.reject" }
        ],
        "Confirmed": [
          { "label": "Готово к выдаче", "variant": "primary", "action": "ready_order" }
        ],
        "Ready for pickup": [
          { "label": "Выдан", "variant": "secondary", "action": "close_order", "opens": "ConfirmDialog.close" }
        ],
        "Rejected": [],
        "Closed": []
      },
      "states": {
        "loading": { "show": "skeleton OrderCards x 4" },
        "empty": {
          "component": "EmptyState",
          "icon": "clipboard-check",
          "title": "Заказов нет",
          "subtitle": "Активные заказы появятся здесь"
        },
        "realtime": {
          "note": "Новый заказ появляется вверху списка с анимацией slide-down",
          "new_order_indicator": {
            "type": "banner",
            "text": "Новый заказ",
            "background": "color.accent",
            "color": "color.text_on_accent",
            "auto_dismiss_ms": 4000
          }
        }
      }
    },
    {
      "id": "availability",
      "tab": "availability",
      "name": "Доступность",
      "roles": ["barista", "administrator"],
      "description": "Временное включение и выключение позиций меню, опций и допов. Цены и структура не меняются.",
      "layout": {
        "mobile": "scroll_vertical",
        "tablet": "two_column — категории слева, позиции справа"
      },
      "elements": [
        {
          "id": "availability_topbar",
          "type": "TopBar",
          "title": "Доступность"
        },
        {
          "id": "availability_category_tabs",
          "type": "HorizontalScrollList",
          "source": "menu_categories",
          "style": "same as orders filter tabs",
          "behavior": "sticky_below_topbar"
        },
        {
          "id": "availability_sections",
          "type": "List",
          "grouping": "by_category",
          "section_component": "SectionList",
          "item_component": "ToggleRow",
          "nested_groups": {
            "description": "Позиция может быть раскрыта для управления вложенными опциями и допами",
            "expand_icon": "chevron-down",
            "nested_item": "ToggleRow",
            "indent": 16
          }
        }
      ],
      "states": {
        "toggle_changed": {
          "feedback": "Toast.success: 'Сохранено'",
          "optimistic_update": true,
          "on_error": "rollback toggle + Toast.error"
        },
        "empty": {
          "component": "EmptyState",
          "icon": "toggle-right",
          "title": "Меню пусто",
          "subtitle": "Позиции появятся после добавления в меню"
        }
      }
    },
    {
      "id": "menu",
      "tab": "menu",
      "name": "Меню",
      "roles": ["administrator"],
      "description": "Управление структурой меню: категории, товары, размеры, группы допов, цены.",
      "layout": {
        "mobile": "stack навигация внутри вкладки",
        "tablet": "three_column — категории / товары / детали"
      },
      "sub_screens": [
        {
          "id": "menu_categories",
          "name": "Категории",
          "description": "Список категорий меню с возможностью добавить, переименовать, удалить.",
          "elements": [
            {
              "id": "menu_categories_topbar",
              "type": "TopBar",
              "title": "Меню",
              "action_right": { "icon": "plus", "action": "open_add_category_modal" }
            },
            {
              "id": "menu_categories_list",
              "type": "SectionList",
              "item": {
                "layout": "row space-between",
                "label": { "font": "typography.scale.h3", "color": "color.text_primary" },
                "count": { "font": "typography.scale.caption", "color": "color.text_muted" },
                "chevron": "chevron-right",
                "action": "navigate to menu_products"
              },
              "swipe_actions": {
                "left": { "label": "Удалить", "color": "color.destructive", "action": "delete_category", "confirm": true }
              }
            }
          ]
        },
        {
          "id": "menu_products",
          "name": "Товары категории",
          "description": "Список товаров внутри категории. Добавление, редактирование, удаление.",
          "elements": [
            {
              "id": "menu_products_topbar",
              "type": "TopBar",
              "back_button": true,
              "title": "{category_name}",
              "action_right": { "icon": "plus", "action": "open_add_product_modal" }
            },
            {
              "id": "menu_products_list",
              "type": "SectionList",
              "item": {
                "layout": "row space-between",
                "image": { "size": 44, "border_radius": "border_radius.sm" },
                "name": { "font": "typography.scale.h3", "color": "color.text_primary" },
                "price_summary": { "font": "typography.scale.caption", "color": "color.text_muted", "content": "от {min_price} ₽" },
                "action": "navigate to menu_product_detail"
              },
              "swipe_actions": {
                "left": { "label": "Удалить", "color": "color.destructive", "action": "delete_product", "confirm": true }
              }
            }
          ]
        },
        {
          "id": "menu_product_detail",
          "name": "Редактирование товара",
          "description": "Форма редактирования товара: название, изображение, размеры с ценами, группы допов.",
          "elements": [
            {
              "id": "product_detail_topbar",
              "type": "TopBar",
              "back_button": true,
              "title": "Товар",
              "action_right": { "label": "Сохранить", "font": "typography.scale.label", "color": "color.accent", "action": "save_product" }
            },
            {
              "id": "product_form",
              "type": "Form",
              "fields": [
                { "id": "name", "component": "FormField", "label": "Название", "type": "text", "required": true },
                { "id": "image", "component": "ImageUpload", "label": "Фото", "aspect_ratio": "1/1" },
                {
                  "id": "sizes_section",
                  "component": "SectionList",
                  "label": "Размеры и цены",
                  "visible_when": "product.has_sizes",
                  "items": [
                    { "size": "S", "component": "FormField", "type": "number", "label": "Цена S, ₽" },
                    { "size": "M", "component": "FormField", "type": "number", "label": "Цена M, ₽" },
                    { "size": "L", "component": "FormField", "type": "number", "label": "Цена L, ₽" }
                  ]
                },
                {
                  "id": "base_price",
                  "component": "FormField",
                  "label": "Цена, ₽",
                  "type": "number",
                  "visible_when": "!product.has_sizes",
                  "required": true
                },
                {
                  "id": "has_sizes_toggle",
                  "component": "ToggleRow",
                  "label": "Размеры S / M / L"
                },
                {
                  "id": "addon_groups_section",
                  "component": "SectionList",
                  "label": "Группы допов",
                  "action_add": { "icon": "plus", "action": "open_add_addon_group_modal" },
                  "item": {
                    "layout": "row space-between",
                    "group_name": { "font": "typography.scale.h3" },
                    "addon_count": { "font": "typography.scale.caption", "color": "color.text_muted" },
                    "action": "navigate to addon_group_detail"
                  }
                }
              ]
            }
          ]
        },
        {
          "id": "addon_group_detail",
          "name": "Группа допов",
          "description": "Настройка группы: название, тип выбора (одиночный/множественный), список допов с ценами.",
          "elements": [
            {
              "id": "addon_group_topbar",
              "type": "TopBar",
              "back_button": true,
              "title": "Группа допов",
              "action_right": { "label": "Сохранить", "action": "save_addon_group" }
            },
            {
              "id": "addon_group_form",
              "type": "Form",
              "fields": [
                { "id": "group_name", "component": "FormField", "label": "Название группы", "type": "text", "required": true },
                {
                  "id": "selection_type",
                  "component": "SegmentedControl",
                  "label": "Тип выбора",
                  "options": [
                    { "value": "single", "label": "Один" },
                    { "value": "multiple", "label": "Несколько" }
                  ]
                },
                {
                  "id": "addons_list",
                  "component": "SectionList",
                  "label": "Допы",
                  "action_add": { "icon": "plus", "action": "add_addon_inline" },
                  "item": {
                    "layout": "row gap-8",
                    "name_field": "FormField.text",
                    "price_field": "FormField.number (0 = бесплатно)",
                    "delete_action": { "icon": "trash", "color": "color.destructive" }
                  }
                }
              ]
            }
          ]
        }
      ],
      "states": {
        "unsaved_changes": {
          "show_indicator": true,
          "on_back_navigate": "ConfirmDialog: 'Есть несохранённые изменения. Выйти?'"
        }
      }
    },
    {
      "id": "users",
      "tab": "users",
      "name": "Пользователи",
      "roles": ["administrator"],
      "description": "Управление пользователями: назначение ролей, блокировка.",
      "layout": {
        "mobile": "scroll_vertical",
        "tablet": "single_column max-width 720px centered"
      },
      "elements": [
        {
          "id": "users_topbar",
          "type": "TopBar",
          "title": "Пользователи",
          "action_right": { "icon": "search", "action": "toggle_search" }
        },
        {
          "id": "users_search",
          "type": "SearchInput",
          "placeholder": "Поиск по имени или Telegram",
          "visible_when": "search_open",
          "border_radius": "border_radius.md",
          "background": "color.background_secondary"
        },
        {
          "id": "users_filter_tabs",
          "type": "HorizontalScrollList",
          "items": [
            { "id": "all", "label": "Все" },
            { "id": "barista", "label": "Баристы" },
            { "id": "blocked", "label": "Заблокированные" }
          ],
          "style": "same as orders filter tabs"
        },
        {
          "id": "users_list",
          "type": "SectionList",
          "item_component": "UserRow",
          "on_tap_action_menu": {
            "items_by_role_and_status": {
              "customer_active": [
                { "label": "Назначить баристой", "action": "assign_barista" },
                { "label": "Заблокировать", "action": "block_user", "style": "destructive" }
              ],
              "barista_active": [
                { "label": "Снять роль баристы", "action": "revoke_barista" },
                { "label": "Заблокировать", "action": "block_user", "style": "destructive" }
              ],
              "any_blocked": [
                { "label": "Разблокировать", "action": "unblock_user" }
              ]
            }
          }
        }
      ],
      "states": {
        "loading": { "show": "skeleton UserRows x 6" },
        "empty": {
          "component": "EmptyState",
          "icon": "users",
          "title": "Пользователей нет",
          "subtitle": "Они появятся после активации бота"
        },
        "action_success": {
          "toast": "Toast.success с описанием действия"
        }
      }
    },
    {
      "id": "settings",
      "tab": "settings",
      "name": "Настройки",
      "roles": ["administrator"],
      "description": "Рабочие часы и вместимость слотов.",
      "layout": {
        "mobile": "scroll_vertical",
        "tablet": "single_column max-width 560px centered"
      },
      "elements": [
        {
          "id": "settings_topbar",
          "type": "TopBar",
          "title": "Настройки"
        },
        {
          "id": "settings_working_hours",
          "type": "SectionList",
          "label": "Рабочие часы",
          "items": [
            {
              "id": "working_hours_open",
              "component": "FormField",
              "label": "Открытие",
              "type": "time",
              "default": "09:00"
            },
            {
              "id": "working_hours_close",
              "component": "FormField",
              "label": "Закрытие",
              "type": "time",
              "default": "20:00"
            }
          ]
        },
        {
          "id": "settings_slot_capacity",
          "type": "SectionList",
          "label": "Слоты",
          "items": [
            {
              "id": "slot_capacity",
              "component": "FormField",
              "label": "Вместимость слота (заказов)",
              "type": "number",
              "min": 1,
              "max": 50,
              "default": 5,
              "hint": "Сколько активных заказов помещается в один 10-минутный слот"
            }
          ]
        },
        {
          "id": "settings_save_button",
          "type": "Button",
          "variant": "primary",
          "label": "Сохранить",
          "action": "save_settings",
          "sticky": "bottom",
          "safe_area_aware": true
        }
      ],
      "states": {
        "saved": { "toast": "Toast.success: 'Настройки сохранены'" },
        "validation_error": {
          "close_after_open": "Время закрытия должно быть позже времени открытия",
          "field_highlight": "border color.destructive"
        }
      }
    }
  ],

  "navigation": {
    "type": "tab_based",
    "default_tab": "orders",
    "tab_component": {
      "mobile": "TabBar",
      "tablet": "SideNav"
    },
    "inner_navigation": {
      "type": "stack",
      "scope": "within tab (menu sub-screens)",
      "transitions": {
        "push": "slide-left",
        "pop": "slide-right",
        "duration": "animation.duration_default"
      }
    },
    "role_guard": {
      "description": "Вкладки menu, users, settings не рендерятся для barista",
      "behavior": "tab hidden, direct URL returns 403 screen"
    }
  },

  "accessibility": {
    "min_touch_target": 44,
    "contrast_ratio_min": 4.5,
    "focus_visible": true
  },

  "adaptivity": {
    "breakpoints": {
      "mobile": "< 768px",
      "tablet": ">= 768px"
    },
    "layout_changes_at_tablet": [
      "TabBar → SideNav",
      "TopBar скрыт, заголовок в контентной зоне",
      "OrderCard список → 2 колонки",
      "menu sub-screens → three_column layout",
      "users и settings → centered single column с max-width"
    ],
    "safe_areas": "respected on all fixed/sticky elements",
    "scroll": "native momentum"
  }
}
