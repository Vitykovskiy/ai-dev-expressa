{
  "name": "expressa",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @expressa/server",
    "build:backoffice": "npm run build --workspace @expressa/backoffice-web",
    "start": "npm run start --workspace @expressa/server",
    "start:dev": "npm run start:dev --workspace @expressa/server",
    "start:dev:backoffice": "npm run dev --workspace @expressa/backoffice-web",
    "test": "npm run test --workspace @expressa/server",
    "test:backoffice": "npm run test --workspace @expressa/backoffice-web"
  }
}
