{
  "name": "expressa",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "dev:backend": "npm run start:dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "lint:backend": "npm run lint --prefix backend",
    "format:check:backend": "npm run format:check --prefix backend",
    "typecheck:backend": "npm run typecheck --prefix backend",
    "test:backend": "npm run test --prefix backend",
    "build:backend": "npm run build --prefix backend",
    "lint:frontend": "npm run lint --prefix frontend",
    "stylelint:frontend": "npm run stylelint --prefix frontend",
    "format:check:frontend": "npm run format:check --prefix frontend",
    "typecheck:frontend": "npm run typecheck --prefix frontend",
    "test:frontend": "npm run test --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "deploy:test:vps": "bash scripts/deploy-test-vps.sh",
    "test:e2e": "npm --prefix e2e test --",
    "quality": "npm run lint:backend && npm run format:check:backend && npm run typecheck:backend && npm run test:backend && npm run lint:frontend && npm run stylelint:frontend && npm run format:check:frontend && npm run typecheck:frontend && npm run test:frontend",
    "build": "npm run build:backend && npm run build:frontend"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  }
}
