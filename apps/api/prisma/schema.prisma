generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SystemRole {
  CUSTOMER
  BARISTA
  ADMINISTRATOR
}

model User {
  id                       String       @id @default(cuid())
  telegramId               String       @unique
  roles                    SystemRole[]
  blocked                  Boolean      @default(false)
  isBootstrapAdministrator Boolean      @default(false)
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
}

model MenuCatalogState {
  id        Int      @id
  snapshot  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SlotSettingsState {
  id          Int      @id
  startTime   String
  endTime     String
  slotCapacity Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

